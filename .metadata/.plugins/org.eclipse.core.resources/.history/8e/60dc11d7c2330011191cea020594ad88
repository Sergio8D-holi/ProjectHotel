package co.edu.uptc.crudHotel.models;

import co.edu.uptc.crudHotel.enums.BedTypeEconomicEnum;

public class EconomicRoom extends Room{
	private BedTypeEconomicEnum bedType;

	public EconomicRoom(int id, int numberBeds, boolean isAvailable, float pricePerNight, boolean bellboyService,
			BedTypeEconomicEnum bedType) {
		super(id, numberBeds, isAvailable, pricePerNight, bellboyService);
		this.bedType = bedType;
	}

	public BedTypeEconomicEnum getBedType() {
		return bedType;
	}

	public void setBedType(BedTypeEconomicEnum bedType) {
		this.bedType = bedType;
	}

}