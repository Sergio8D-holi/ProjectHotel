package co.edu.uptc.crudHotel.models;

import java.util.Date;

import co.edu.uptc.crudHotel.Logic.BaseClass;

public class Reservation extends BaseClass{
	private Room room;
	private Customer customer;
	private Date arrivalDate;
	private int reservedDays;
	
	public Reservation(Room room, Customer customer, Date arrivalDate, int reservedDays) {
		super();
		this.room = room;
		this.customer = customer;
		this.arrivalDate = arrivalDate;
		this.reservedDays = reservedDays;
	}

	public Room getRoom() {
		return room;
	}

	public Customer getCustomer() {
		return customer;
	}

	public Date getArrivalDate() {
		return arrivalDate;
	}

	public int getReservedDays() {
		return reservedDays;
	}
	
	
}
