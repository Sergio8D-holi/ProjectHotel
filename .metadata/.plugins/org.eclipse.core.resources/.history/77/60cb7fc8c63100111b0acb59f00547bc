package co.edu.uptc.crudHotel.models;

import co.edu.uptc.crudHotel.Logic.BaseClass;

public class Room extends BaseClass{
	protected int numberBeds;
	protected boolean isAvailable;
	protected float pricePerNight;
	protected Bellboy bellboyService;
	protected float extraCost;
	
	public Room(int numberBeds, boolean isAvailable, float pricePerNight, Bellboy bellboyService, float extraCost) {
		super();
		this.numberBeds = numberBeds;
		this.isAvailable = isAvailable;
		this.pricePerNight = pricePerNight;
		this.bellboyService = bellboyService;
		this.extraCost = extraCost;
	}

	public int getNumberBeds() {
		return numberBeds;
	}

	public boolean isAvailable() {
		return isAvailable;
	}

	public float getPricePerNight() {
		return pricePerNight;
	}

	public Bellboy getBellboyService() {
		return bellboyService;
	}

	public float getExtraCost() {
		return extraCost;
	}
	
}
